# ═══════════════════════════════════════════════════════════════════════
#  🏛️ Sovereign Software Factory — Environment Configuration
#  Copy this to .env and customize
# ═══════════════════════════════════════════════════════════════════════

# ─── AOS Gateway ──────────────────────────────────────────────────────
# Optional API key for bearer token auth (leave empty to disable)
AOS_API_KEY=

# ─── TurboQuant GPU Engine ────────────────────────────────────────────
# Path to your local models directory
MODELS_DIR=/home/maximilian-wruhs/.lmstudio/models

# Model filename inside MODELS_DIR (e.g. deepseek-r1/deepseek-r1-14b-Q4_K_M.gguf)
TURBOQUANT_MODEL=deepseek-r1/deepseek-r1-14b-Q4_K_M.gguf

# Context window size
TURBOQUANT_CTX=8192

# Number of layers to offload to GPU (-1 or 99 = all)
TURBOQUANT_GPU_LAYERS=99

# ─── pgvector Database ────────────────────────────────────────────────
PG_USER=aos
PG_PASSWORD=aos_sovereign
PG_DB=aos_vectors
